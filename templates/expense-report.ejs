<%
  // Rendered by SaveExpenseReportTool. `locals` provides:
  //   generatedAt : ISO timestamp string
  //   categories  : CategoryExpense[] (already ordered by total DESC)
  //   totals      : { base, vat, total, deductible, lineCount }
  // All monetary formatting happens here so the tool stays data-only.
  const money = (n) =>
    new Intl.NumberFormat('es-EC', { style: 'currency', currency: 'USD' }).format(n || 0)
  const pct = (part, whole) => (whole > 0 ? ((part / whole) * 100) : 0)
  const generated = new Date(generatedAt)
  const generatedLabel = new Intl.DateTimeFormat('es-EC', {
    dateStyle: 'long',
    timeStyle: 'short',
  }).format(generated)
  // Palette per category — stable colors so the same rubro always looks the same.
  const COLORS = {
    VIVIENDA: '#2563eb',
    SALUD: '#dc2626',
    EDUCACION: '#7c3aed',
    ALIMENTACION: '#16a34a',
    VESTIMENTA: '#db2777',
    TURISMO: '#0891b2',
    NEGOCIO: '#ea580c',
    NO_DEDUCIBLE: '#64748b',
  }
  const LABELS = {
    VIVIENDA: 'Vivienda',
    SALUD: 'Salud',
    EDUCACION: 'Educación',
    ALIMENTACION: 'Alimentación',
    VESTIMENTA: 'Vestimenta',
    TURISMO: 'Turismo',
    NEGOCIO: 'Negocio',
    NO_DEDUCIBLE: 'No deducible',
  }
  const color = (c) => COLORS[c] || '#64748b'
  const label = (c) => LABELS[c] || c
%>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reporte de gastos por categoría</title>
  <style>
    :root {
      --bg: #f1f5f9;
      --card: #ffffff;
      --ink: #0f172a;
      --muted: #64748b;
      --border: #e2e8f0;
      --shadow: 0 1px 3px rgba(15, 23, 42, 0.08), 0 8px 24px rgba(15, 23, 42, 0.05);
      --radius: 14px;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0b1120;
        --card: #111a2e;
        --ink: #e2e8f0;
        --muted: #94a3b8;
        --border: #22304d;
        --shadow: 0 1px 3px rgba(0, 0, 0, 0.4), 0 8px 24px rgba(0, 0, 0, 0.35);
      }
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    .wrap { max-width: 960px; margin: 0 auto; padding: 32px 20px 64px; }
    header.report-head { margin-bottom: 28px; }
    header.report-head h1 {
      margin: 0 0 6px;
      font-size: clamp(1.5rem, 4vw, 2rem);
      letter-spacing: -0.02em;
    }
    header.report-head p { margin: 0; color: var(--muted); font-size: 0.9rem; }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      box-shadow: var(--shadow);
    }
    .card .k { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
    .card .v { font-size: 1.55rem; font-weight: 700; margin-top: 6px; letter-spacing: -0.02em; }
    .card .sub { font-size: 0.8rem; color: var(--muted); margin-top: 2px; }
    .card.accent .v { color: #16a34a; }

    .panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .panel h2 {
      margin: 0;
      padding: 18px 20px;
      font-size: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; min-width: 640px; }
    thead th {
      text-align: right;
      font-weight: 600;
      color: var(--muted);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    thead th:first-child, tbody td:first-child { text-align: left; }
    tbody td { padding: 14px 16px; text-align: right; border-bottom: 1px solid var(--border); white-space: nowrap; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: color-mix(in srgb, var(--ink) 3%, transparent); }
    .cat { display: inline-flex; align-items: center; gap: 9px; font-weight: 600; }
    .dot { width: 10px; height: 10px; border-radius: 50%; flex: none; }
    .num { font-variant-numeric: tabular-nums; }
    .bar { height: 6px; border-radius: 4px; margin-top: 6px; min-width: 4px; }
    .share { min-width: 120px; text-align: left; }
    .share .num { display: block; font-size: 0.8rem; color: var(--muted); }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
    .badge.yes { background: rgba(22, 163, 74, 0.15); color: #16a34a; }
    .badge.no { background: rgba(100, 116, 139, 0.15); color: var(--muted); }
    tfoot td {
      padding: 14px 16px;
      text-align: right;
      font-weight: 700;
      border-top: 2px solid var(--border);
      white-space: nowrap;
    }
    tfoot td:first-child { text-align: left; }

    .empty { padding: 48px 20px; text-align: center; color: var(--muted); }
    footer.report-foot { margin-top: 28px; text-align: center; color: var(--muted); font-size: 0.8rem; }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="report-head">
      <h1>Reporte de gastos por categoría</h1>
      <p>Generado el <%= generatedLabel %></p>
    </header>

    <% if (categories.length === 0) { %>
      <div class="panel"><div class="empty">No hay líneas clasificadas para reportar todavía.</div></div>
    <% } else { %>
      <section class="cards">
        <div class="card">
          <div class="k">Gasto total</div>
          <div class="v num"><%= money(totals.total) %></div>
          <div class="sub"><%= totals.lineCount %> líneas · <%= categories.length %> categorías</div>
        </div>
        <div class="card accent">
          <div class="k">Base deducible</div>
          <div class="v num"><%= money(totals.deductible) %></div>
          <div class="sub"><%= pct(totals.deductible, totals.base).toFixed(1) %>% de la base imponible</div>
        </div>
        <div class="card">
          <div class="k">Base imponible</div>
          <div class="v num"><%= money(totals.base) %></div>
          <div class="sub">Sin IVA</div>
        </div>
        <div class="card">
          <div class="k">IVA</div>
          <div class="v num"><%= money(totals.vat) %></div>
          <div class="sub">Impuesto acumulado</div>
        </div>
      </section>

      <section class="panel">
        <h2>Detalle por categoría</h2>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Categoría</th>
                <th>Líneas</th>
                <th>Base</th>
                <th>IVA</th>
                <th>Total</th>
                <th>Deducible</th>
                <th class="share">% del total</th>
              </tr>
            </thead>
            <tbody>
              <% categories.forEach((row) => { const share = pct(row.total, totals.total); %>
                <tr>
                  <td>
                    <span class="cat">
                      <span class="dot" style="background: <%= color(row.category) %>"></span>
                      <%= label(row.category) %>
                    </span>
                  </td>
                  <td class="num"><%= row.lineCount %></td>
                  <td class="num"><%= money(row.base) %></td>
                  <td class="num"><%= money(row.vat) %></td>
                  <td class="num"><%= money(row.total) %></td>
                  <td class="num">
                    <% if (row.deductible > 0) { %>
                      <span class="badge yes"><%= money(row.deductible) %></span>
                    <% } else { %>
                      <span class="badge no">—</span>
                    <% } %>
                  </td>
                  <td class="share">
                    <span class="num"><%= share.toFixed(1) %>%</span>
                    <div class="bar" style="width: <%= Math.max(share, 2).toFixed(1) %>%; background: <%= color(row.category) %>"></div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr>
                <td>Total</td>
                <td class="num"><%= totals.lineCount %></td>
                <td class="num"><%= money(totals.base) %></td>
                <td class="num"><%= money(totals.vat) %></td>
                <td class="num"><%= money(totals.total) %></td>
                <td class="num"><%= money(totals.deductible) %></td>
                <td class="share"><span class="num">100%</span></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </section>
    <% } %>

    <footer class="report-foot">Pony · Reporte de clasificación de gastos</footer>
  </div>
</body>
</html>
