{
  "name": "pony",
  "version": "0.1.0",
  "description": "TypeScript project with Effect and Biome",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@effect/platform": "^0.96.2",
    "better-sqlite3": "^12.11.1",
    "effect": "^3.21.4",
    "openai": "^6.45.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
